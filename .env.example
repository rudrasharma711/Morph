# ---------------------------------------------------------------------------
# Morph — environment variables
# Copy this file to `.env.local` and fill in the values. `.env.local` is
# git-ignored and is read automatically by Next.js.
# ---------------------------------------------------------------------------

# Brevo (https://brevo.com) — powers the waitlist. Free plan = UNLIMITED
# contacts (300 emails/day sending cap on free).
# Used server-side by /api/waitlist to add signups to your contact list.

# Brevo → Settings → SMTP & API → API keys
BREVO_API_KEY=

# The numeric id of your "Waitlist" contact list
# (Brevo → Contacts → Lists → click your list → the id is in the URL / list settings)
BREVO_LIST_ID=

# Notes:
# - If BREVO_API_KEY is empty in development, the waitlist form succeeds as a
#   no-op so you can test the UI; in production an empty key returns an error.
